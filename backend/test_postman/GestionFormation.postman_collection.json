              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/participants",
            "body": {
              "mode": "raw",
              "raw": "{\"nom\": \"Chaabane\", \"prenom\": \"Rania\", \"email\": \"rania@green.tn\", \"tel\": \"99001122\", \"structureId\": 1, \"profilId\": 1}"
            }
          }
        },
        {
          "name": "Modifier un participant",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/participants/1",
            "body": {
              "mode": "raw",
              "raw": "{\"nom\": \"Chaabane\", \"prenom\": \"Rania\", \"email\": \"rania.c@green.tn\", \"structureId\": 1, \"profilId\": 1}"
            }
          }
        },
        {
          "name": "Historique formations d'un participant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/participants/1/formations"
          }
        },
        {
          "name": "Supprimer un participant",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/participants/1"
          }
        }
      ]
    },
    {
      "name": "Formations",
      "item": [
        {
          "name": "Lister toutes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/formations"
          }
        },
        {
          "name": "Filtrer par année",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base}}/formations?annee=2024",
              "query": [{ "key": "annee", "value": "2024" }]
            }
          }
        },
        {
          "name": "Créer une formation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formations",
            "body": {
              "mode": "raw",
              "raw": "{\"titre\": \"Formation Spring Boot\", \"annee\": 2025, \"duree\": 3, \"budget\": 1500.0, \"lieu\": \"Tunis\", \"domaineId\": 1, \"formateurId\": 1, \"participantIds\": [1, 2, 3, 4]}"
            }
          }
        },
        {
          "name": "Modifier une formation",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formations/1",
            "body": {
              "mode": "raw",
              "raw": "{\"titre\": \"Formation Spring Boot Avancé\", \"annee\": 2025, \"duree\": 5, \"budget\": 2000.0, \"lieu\": \"Tunis\", \"domaineId\": 1}"
            }
          }
        },
        {
          "name": "Ajouter des participants",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formations/1/participants",
            "body": { "mode": "raw", "raw": "[5, 6]" }
          }
        },
        {
          "name": "Retirer un participant",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/formations/1/participants/5"
          }
        },
        {
          "name": "Supprimer une formation",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/formations/1"
          }
        }
      ]
