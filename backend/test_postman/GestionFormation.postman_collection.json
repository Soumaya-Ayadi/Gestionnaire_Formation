{
  "info": {
    "name": "Gestion Formation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base", "value": "http://localhost:8081/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "pm.collectionVariables.set('token', json.token);",
                "pm.test('Login réussi', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"login\": \"admin\", \"password\": \"Admin@2025\"}"
            }
          }
        },
        {
          "name": "Créer un compte utilisateur (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/auth/create-user",
            "body": {
              "mode": "raw",
              "raw": "{\"login\": \"user1\", \"email\": \"user1@formation.tn\", \"role\": \"ROLE_USER\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Domaines",
      "item": [
        {
          "name": "Lister tous",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/domaines"
          }
        },
        {
          "name": "Créer un domaine",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/domaines",
            "body": { "mode": "raw", "raw": "{\"libelle\": \"Informatique\"}" }
          }
        },
        {
          "name": "Modifier un domaine",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/domaines/1",
            "body": { "mode": "raw", "raw": "{\"libelle\": \"Informatique & Réseaux\"}" }
          }
        },
        {
          "name": "Supprimer un domaine",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/domaines/1"
          }
        }
      ]
    },
    {
      "name": "Structures",
      "item": [
        {
          "name": "Lister toutes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/structures"
          }
        },
        {
          "name": "Créer une structure",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/structures",
            "body": { "mode": "raw", "raw": "{\"libelle\": \"Direction Informatique\", \"type\": \"CENTRALE\"}" }
          }
        }
      ]
    },
    {
      "name": "Profils",
      "item": [
        {
          "name": "Lister tous",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/profils"
          }
        },
        {
          "name": "Créer un profil",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/profils",
            "body": { "mode": "raw", "raw": "{\"libelle\": \"Informaticien Bac+5\"}" }
          }
        }
      ]
    },
    {
      "name": "Employeurs",
      "item": [
