              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formateurs",
            "body": {
              "mode": "raw",
              "raw": "{\"nom\": \"Ben Ali\", \"prenom\": \"Sami\", \"email\": \"sami.benali@green.tn\", \"tel\": \"22334455\", \"type\": \"INTERNE\"}"
            }
          }
        },
        {
          "name": "Créer formateur externe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formateurs",
            "body": {
              "mode": "raw",
              "raw": "{\"nom\": \"Trabelsi\", \"prenom\": \"Imen\", \"email\": \"imen.t@externe.tn\", \"tel\": \"55667788\", \"type\": \"EXTERNE\", \"employeurId\": 1}"
            }
          }
        },
        {
          "name": "Modifier un formateur",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base}}/formateurs/1",
            "body": {
              "mode": "raw",
              "raw": "{\"nom\": \"Ben Ali\", \"prenom\": \"Sami\", \"email\": \"sami@green.tn\", \"type\": \"INTERNE\"}"
            }
          }
        },
        {
